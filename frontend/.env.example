# URL base da API.
# Copie este arquivo para .env e ajuste conforme seu ambiente:
#
#   Emulador Android  →  http://10.0.2.2:3000          (padrão, não precisa mudar)
#   Device físico     →  http://<SEU_IP_WIFI>:3000      (veja como descobrir abaixo)
#   iOS Simulator     →  http://localhost:3000
#   Web               →  http://localhost:3000
#
# Como descobrir seu IP Wi-Fi (Windows):
#   Abra o terminal e rode: ipconfig
#   Use o IP da linha "Adaptador de Rede sem Fio Wi-Fi → Endereço IPv4"
#   Exemplo: EXPO_PUBLIC_API_URL=http://192.168.1.10:3000
#
# IMPORTANTE: reinicie o `npx expo start` após alterar este arquivo.

EXPO_PUBLIC_API_URL=http://10.0.2.2:3000
